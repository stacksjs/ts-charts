{
  "name": "@ts-charts/charts",
  "version": "0.2.0",
  "type": "module",
  "description": "A complete TypeScript rewrite of D3.js — umbrella package re-exporting all sub-packages.",
  "author": "Chris Breuer <chris@stacksjs.com>",
  "license": "MIT",
  "homepage": "https://github.com/stacksjs/ts-charts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stacksjs/ts-charts.git"
  },
  "bugs": {
    "url": "https://github.com/stacksjs/ts-charts/issues"
  },
  "keywords": [
    "d3",
    "charts",
    "visualization",
    "typescript",
    "bun"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun --bun build.ts",
    "prepublishOnly": "bun --bun run build",
    "test": "bun test"
  },
  "dependencies": {
    "@ts-charts/array": "workspace:*",
    "@ts-charts/axis": "workspace:*",
    "@ts-charts/brush": "workspace:*",
    "@ts-charts/chord": "workspace:*",
    "@ts-charts/color": "workspace:*",
    "@ts-charts/contour": "workspace:*",
    "@ts-charts/delaunay": "workspace:*",
    "@ts-charts/dispatch": "workspace:*",
    "@ts-charts/drag": "workspace:*",
    "@ts-charts/dsv": "workspace:*",
    "@ts-charts/ease": "workspace:*",
    "@ts-charts/fetch": "workspace:*",
    "@ts-charts/force": "workspace:*",
    "@ts-charts/format": "workspace:*",
    "@ts-charts/geo": "workspace:*",
    "@ts-charts/hierarchy": "workspace:*",
    "@ts-charts/interpolate": "workspace:*",
    "@ts-charts/path": "workspace:*",
    "@ts-charts/polygon": "workspace:*",
    "@ts-charts/quadtree": "workspace:*",
    "@ts-charts/random": "workspace:*",
    "@ts-charts/scale": "workspace:*",
    "@ts-charts/scale-chromatic": "workspace:*",
    "@ts-charts/selection": "workspace:*",
    "@ts-charts/shape": "workspace:*",
    "@ts-charts/time": "workspace:*",
    "@ts-charts/time-format": "workspace:*",
    "@ts-charts/timer": "workspace:*",
    "@ts-charts/transition": "workspace:*",
    "@ts-charts/zoom": "workspace:*"
  }
}
